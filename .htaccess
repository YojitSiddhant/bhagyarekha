Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# If the requested resource exists, serve it directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Frontend routes
RewriteRule ^$ index.php?page=home [L,QSA]
RewriteRule ^(about|services|gallery|contact)/?$ index.php?page=$1 [L,QSA]
</IfModule>

