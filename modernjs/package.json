{
  "name": "bhagyarekha-modernjs",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @bhagyarekha/web run dev",
    "dev:api": "npm --workspace @bhagyarekha/api run start:dev",
    "dev": "concurrently -n web,api -c magenta,cyan \"npm run dev:web\" \"npm run dev:api\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

